+fn is_inference_lifecycle_event(kind: &str) -> bool {
+    kind == "response.created"
+        || kind == "response.in_progress"
+        || kind.starts_with("response.output_")
+        || kind.starts_with("response.reasoning_")
+}
+
+fn unix_time_ns() -> u128 {
+    SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .unwrap_or_default()
+        .as_nanos()
+}
+
+fn emit_responses_websocket_lifecycle_event(
+    payload: &str,
+    context: &ResponsesWebsocketTimingLogContext,
+    request_sent_at: Instant,
+    request_sent_unix_ns: u128,
+    provider_event_started_at: Option<Instant>,
+    provider_event_started_unix_ns: Option<u128>,
+    provider_start_kind: Option<&str>,
+) {
+    let completed_at = Instant::now();
+    let completed_unix_ns = unix_time_ns();
+    let request_to_completed_ms =
+        completed_at.duration_since(request_sent_at).as_secs_f64() * 1000.0;
+    let provider_event_window_ms = provider_event_started_at
+        .map(|started_at| completed_at.duration_since(started_at).as_secs_f64() * 1000.0)
+        .unwrap_or(request_to_completed_ms);
+    let value = serde_json::from_str::<Value>(payload).unwrap_or(Value::Null);
+    let response = value.get("response").unwrap_or(&Value::Null);
+    let usage = response.get("usage").unwrap_or(&Value::Null);
+    let output_details = usage.get("output_tokens_details").unwrap_or(&Value::Null);
+    let response_id = response
+        .get("id")
+        .and_then(Value::as_str)
+        .unwrap_or_default();
+    let input_tokens = usage
+        .get("input_tokens")
+        .and_then(Value::as_i64)
+        .unwrap_or_default();
+    let output_tokens = usage
+        .get("output_tokens")
+        .and_then(Value::as_i64)
+        .unwrap_or_default();
+    let reasoning_output_tokens = output_details
+        .get("reasoning_tokens")
+        .and_then(Value::as_i64)
+        .unwrap_or_default();
+
+    tracing::event!(
+        target: RESPONSES_WEBSOCKET_LIFECYCLE_EVENT_TARGET,
+        tracing::Level::TRACE,
+        model = context.model.as_str(),
+        session_id = context.session_id.as_deref().unwrap_or_default(),
+        thread_id = context.thread_id.as_deref().unwrap_or_default(),
+        turn_id = context.turn_id.as_deref().unwrap_or_default(),
+        previous_response_id = context.previous_response_id.as_deref().unwrap_or_default(),
+        response_id,
+        warmup = context.warmup,
+        connection_reused = context.connection_reused,
+        request_sent_unix_ns = request_sent_unix_ns.to_string(),
+        provider_event_started_unix_ns = provider_event_started_unix_ns
+            .unwrap_or(request_sent_unix_ns)
+            .to_string(),
+        completed_unix_ns = completed_unix_ns.to_string(),
+        provider_start_kind = provider_start_kind.unwrap_or("request_sent_fallback"),
+        request_to_completed_ms,
+        provider_event_window_ms,
+        input_tokens,
+        output_tokens,
+        reasoning_output_tokens,
+        "responses websocket lifecycle"
+    );
+}
+
+fn emit_responses_websocket_timing_event(
+    kind: &str,
+    payload: &str,
+    context: &ResponsesWebsocketTimingLogContext,
+) {
+    if kind != RESPONSES_WEBSOCKET_TIMING_KIND {
+        return;
+    }
+
+    tracing::event!(
+        name: RESPONSES_WEBSOCKET_TIMING_KIND,
+        target: RESPONSES_WEBSOCKET_TIMING_EVENT_TARGET,
+        tracing::Level::TRACE,
+        model = context.model.as_str(),
+        session_id = context.session_id.as_deref().unwrap_or_default(),
+        thread_id = context.thread_id.as_deref().unwrap_or_default(),
+        turn_id = context.turn_id.as_deref().unwrap_or_default(),
+        previous_response_id = context.previous_response_id.as_deref().unwrap_or_default(),
+        request_start_ms = context.request_start_ms.as_deref().unwrap_or_default(),
+        warmup = context.warmup,
+        connection_reused = context.connection_reused,
+        payload,
+        "responses websocket timing"
+    );
+}
